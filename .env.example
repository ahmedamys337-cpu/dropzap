# DropZap environment variables
# Copy this file to .env.local for local dev, or set these in your hosting provider
# (Render, SnapDeploy, etc.) for production.

# ============================================================================
# REQUIRED — App will not start correctly without these
# ============================================================================

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1

# The canonical URL of your deployed site (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://www.dropzap.digital

# ============================================================================
# OPTIONAL — Downloader enhancement (leave empty = app still works)
# ============================================================================

# Cobalt API key for higher rate limits. Without it, app uses public instances.
# Get a free key at: https://cobalt.tools/settings/api
COBALT_API_KEY=
COBALT_API_URLS=

# YouTube cookies (Netscape format) for yt-dlp. Leave empty if not needed.
YOUTUBE_COOKIES=
# Proxy URLs for yt-dlp. Leave empty to skip.
YOUTUBE_PROXIES=

# ============================================================================
# OPTIONAL — Analytics & Ads (leave empty = disabled)
# ============================================================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ============================================================================
# SEO OUTREACH SCRIPTS — Only needed for scripts/seo-outreach/
# NOT required for the web app. See scripts/seo-outreach/.env.example
# ============================================================================
