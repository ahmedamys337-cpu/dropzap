# DropZap environment variables
# Copy this file to .env.local for local dev, or set these in your hosting provider
# (Render, Vercel, Netlify, etc.) for production.

# ============================================================================
# SITE CONFIGURATION
# ============================================================================

# The canonical URL of your deployed site (no trailing slash).
# This is used in sitemap.xml, OG tags, JSON-LD schema, and canonical links.
# Examples:
#   - Local dev:    http://localhost:3000
#   - Render:       https://dropzap.onrender.com
#   - Custom domain: https://dropzap.app
NEXT_PUBLIC_SITE_URL=https://dropzap.app

# ============================================================================
# ANALYTICS
# ============================================================================

# Google Analytics 4 Measurement ID (starts with G-).
# Get yours at: https://analytics.google.com/
# Leave empty to disable analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Search Console verification codes (just the code, not the full meta tag).
# Google:  https://search.google.com/search-console  -> HTML tag method -> copy the `content="..."` value
# Bing:    https://www.bing.com/webmasters
# Yandex:  https://webmaster.yandex.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ============================================================================
# YOUTUBE DOWNLOADER (server-side only)
# ============================================================================

# Pipe-separated YouTube cookies string (Netscape format) used by yt-dlp
# to bypass age/login restrictions and IP blocks. Export from your browser
# using a "Get cookies.txt" extension and paste the file contents here.
# Leave empty if you don't have cookies.
YOUTUBE_COOKIES=

# Pipe-separated proxy URLs for yt-dlp rotation. Format:
#   http://user:pass@host:port|http://user2:pass2@host2:port2|socks5://...
# Use residential proxies for best results. Leave empty to skip proxies.
YOUTUBE_PROXIES=

# ============================================================================
# OPTIONAL: ADSENSE / AFFILIATE
# ============================================================================

# Google AdSense publisher ID (e.g. ca-pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=

# ============================================================================
# SEO ARTICLE PUBLISHING (used by scripts/seo-outreach/publish-articles.mjs)
# ============================================================================

# Dev.to API key — Settings → Extensions → "DEV Community API Keys"
# https://dev.to/settings/extensions
DEVTO_API_KEY=

# Medium Integration Token — Settings → Security → "Integration tokens"
# https://medium.com/me/settings
MEDIUM_INTEGRATION_TOKEN=

# HackMD API token — Settings → API → "New API Token"
# https://hackmd.io/settings#api
HACKMD_API_TOKEN=

# ============================================================================
# BACKLINK AUTOMATION — GITHUB GISTS  (DA 96)
# ============================================================================
# Personal Access Token with "gist" scope ONLY (minimal permissions).
# Create at: https://github.com/settings/tokens/new → check "gist"
GITHUB_GIST_TOKEN=

# ============================================================================
# BACKLINK AUTOMATION — TUMBLR  (DA 75)
# ============================================================================
# 1. Create app at https://www.tumblr.com/oauth/apps
# 2. Get Consumer Key + Secret from the app page
# 3. Get Access Token + Secret by running OAuth flow
TUMBLR_BLOG_NAME=
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
TUMBLR_ACCESS_TOKEN=
TUMBLR_TOKEN_SECRET=

# ============================================================================
# BACKLINK AUTOMATION — DIIGO BOOKMARKS  (DA 92)
# ============================================================================
# Get API key at: https://www.diigo.com/api_keys/new/
DIIGO_USERNAME=
DIIGO_API_KEY=

# ============================================================================
# BACKLINK AUTOMATION — REDDIT POSTING  (DA 91)
# ============================================================================
# Create a "script" type app at: https://www.reddit.com/prefs/apps
# Name: DropZap SEO | redirect: http://localhost
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
